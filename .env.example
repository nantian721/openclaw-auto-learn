# OpenClaw Auto-Learn 配置文件示例
# 使用说明：
# 1. 复制本文件为 .env
# 2. 填写你的实际配置
# 3. 确保 .env 不会被提交到 Git（已在 .gitignore 中配置）
#
# ⚠️ 安全警告：
# - 永远不要将真实的 .env 文件提交到 GitHub
# - 如果误提交，立即到对应平台撤销 API Key
# - 所有敏感信息仅保存在本地

# ============================================
# 邮件配置（用于接收学习汇报）
# ============================================

# SMTP 服务器地址
# Gmail: smtp.gmail.com
# 163: smtp.163.com
# QQ: smtp.qq.com
SMTP_HOST=smtp.gmail.com

# SMTP 端口
# TLS: 587
# SSL: 465
SMTP_PORT=587

# 发件人邮箱
SMTP_USER=your-email@gmail.com

# 邮箱密码/应用专用密码
# Gmail: 使用应用专用密码 https://myaccount.google.com/apppasswords
# 163/QQ: 使用授权码
SMTP_PASS=your-app-password

# 收件人邮箱（可以和发件人相同）
NOTIFY_EMAIL=your-email@gmail.com

# ============================================
# 可选：其他 API 配置（根据技能需求）
# ============================================

# OpenAI API Key（某些技能可能需要）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# 百度千帆 API（如需使用百度相关技能）
# QIANFAN_ACCESS_KEY=your-access-key
# QIANFAN_SECRET_KEY=your-secret-key

# 其他 API Keys...
